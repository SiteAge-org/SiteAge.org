---
import Base from "../layouts/Base.astro";
import JsonLd from "../components/JsonLd.astro";
import { API_BASE_URL } from "@siteage/shared";
import type { GlobalStats } from "@siteage/shared";

const apiBase = import.meta.env.PUBLIC_API_URL || API_BASE_URL;

interface DecadeData {
  decade: string;
  count: number;
}

interface OldestDomain {
  domain: string;
  birth_at: string;
  verification_status: string;
}

let stats: GlobalStats | null = null;
let distribution: DecadeData[] = [];
let topOldest: OldestDomain[] = [];

const [statsResp, distResp, oldestResp] = await Promise.allSettled([
  fetch(`${apiBase}/stats`),
  fetch(`${apiBase}/stats/distribution`),
  fetch(`${apiBase}/stats/top-oldest?limit=10`),
]);

if (statsResp.status === "fulfilled" && statsResp.value.ok) {
  stats = await statsResp.value.json() as GlobalStats;
}
if (distResp.status === "fulfilled" && distResp.value.ok) {
  const data = await distResp.value.json() as { distribution: DecadeData[] };
  distribution = data.distribution || [];
}
if (oldestResp.status === "fulfilled" && oldestResp.value.ok) {
  const data = await oldestResp.value.json() as { domains: OldestDomain[] };
  topOldest = data.domains || [];
}

// Calculate max count for bar chart scaling
const maxCount = Math.max(...distribution.map((d) => d.count), 1);

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: "https://siteage.org" },
    { "@type": "ListItem", position: 2, name: "Stats" },
  ],
};

const datasetSchema = {
  "@context": "https://schema.org",
  "@type": "Dataset",
  name: "SiteAge.org Website Age Statistics",
  description: "Aggregated statistics about certified website ages from multiple archival sources.",
  url: "https://siteage.org/stats",
  provider: { "@type": "Organization", name: "SiteAge.org" },
};
---

<Base
  title="Platform Statistics"
  description="Explore SiteAge.org statistics: total certifications, decade distribution, and the oldest websites on record."
  ogTitle="Platform Statistics | SiteAge.org"
  ogDescription="Data insights from SiteAge.org: website age distribution, oldest domains, and certification stats."
>
  <JsonLd data={breadcrumbSchema} />
  <JsonLd data={datasetSchema} />

  <!-- Header -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-parchment-dark/40 to-parchment noise-overlay"></div>
    <div class="relative max-w-3xl mx-auto px-6 pt-16 pb-10 text-center">
      <span class="text-xs tracking-[0.3em] uppercase text-seal-dark font-medium">Insights</span>
      <h1 class="font-display text-3xl sm:text-4xl mt-4 text-ink">Platform Statistics</h1>
      <p class="text-ink-muted mt-4 max-w-xl mx-auto font-light leading-relaxed">
        Real-time data about websites certified on SiteAge.org.
      </p>
      <div class="ornament-line max-w-32 mx-auto mt-5"></div>
    </div>
  </section>

  <div class="max-w-4xl mx-auto px-6 pb-16 sm:pb-24 space-y-12">
    <!-- Overview stats -->
    {stats && (
      <section class="grid grid-cols-2 sm:grid-cols-4 gap-6">
        <div class="card-base p-6 text-center">
          <div class="font-display text-3xl text-ink">{stats.total_domains.toLocaleString()}</div>
          <div class="text-xs tracking-[0.15em] uppercase text-ink-muted/50 font-medium mt-2">Total Certified</div>
        </div>
        <div class="card-base p-6 text-center">
          <div class="font-display text-3xl text-ink">{stats.active_domains.toLocaleString()}</div>
          <div class="text-xs tracking-[0.15em] uppercase text-ink-muted/50 font-medium mt-2">Active</div>
        </div>
        <div class="card-base p-6 text-center">
          <div class="font-display text-3xl text-ink">{stats.verified_domains.toLocaleString()}</div>
          <div class="text-xs tracking-[0.15em] uppercase text-ink-muted/50 font-medium mt-2">Verified</div>
        </div>
        <div class="card-base p-6 text-center">
          <div class="font-display text-3xl text-ink">{stats.dead_domains.toLocaleString()}</div>
          <div class="text-xs tracking-[0.15em] uppercase text-ink-muted/50 font-medium mt-2">Memorial</div>
        </div>
      </section>
    )}

    <!-- Decade distribution -->
    {distribution.length > 0 && (
      <section class="card-base p-8 sm:p-10">
        <h2 class="card-title">Age Distribution by Decade</h2>
        <div class="space-y-4 mt-6">
          {distribution.map((d) => {
            const pct = maxCount > 0 ? (d.count / maxCount) * 100 : 0;
            return (
              <div class="flex items-center gap-4">
                <span class="font-mono text-sm text-ink-muted w-12 text-right flex-shrink-0">{d.decade}</span>
                <div class="flex-1 h-8 bg-parchment-dark/50 rounded-sm overflow-hidden relative">
                  <div
                    class="h-full bg-gradient-to-r from-seal/30 to-seal/50 rounded-sm transition-all duration-500"
                    style={`width: ${Math.max(pct, 2)}%`}
                  ></div>
                </div>
                <span class="font-mono text-sm text-ink-muted w-10 flex-shrink-0">{d.count}</span>
              </div>
            );
          })}
        </div>
      </section>
    )}

    <!-- Top oldest -->
    {topOldest.length > 0 && (
      <section class="card-base p-8 sm:p-10">
        <h2 class="card-title">Oldest Websites</h2>
        <div class="space-y-3 mt-6">
          {topOldest.map((d, i) => {
            const year = new Date(d.birth_at).getUTCFullYear();
            const isVerified = d.verification_status === "verified";
            const rankColor = i === 0 ? "text-seal-dark" : i === 1 ? "text-ink-muted" : i === 2 ? "text-seal-dark/60" : "text-ink-muted/40";
            return (
              <a href={`/${d.domain}`} class="flex items-center gap-4 py-2 px-3 -mx-3 rounded-sm hover:bg-parchment-dark/30 transition-colors group">
                <span class={`font-display text-lg w-8 text-right flex-shrink-0 ${rankColor}`}>
                  {i + 1}
                </span>
                <span class="flex-1 font-mono text-sm text-ink group-hover:text-azure transition-colors truncate">{d.domain}</span>
                {isVerified && (
                  <span class="flex-shrink-0 text-[10px] tracking-[0.1em] uppercase text-seal-dark font-medium bg-seal/[0.08] px-1.5 py-0.5">Verified</span>
                )}
                <span class="flex-shrink-0 text-sm text-ink-muted font-light">{year}</span>
              </a>
            );
          })}
        </div>
      </section>
    )}

    <!-- CTA -->
    <div class="text-center">
      <div class="ornament-line max-w-24 mx-auto mb-6"></div>
      <p class="text-ink-muted font-light mb-4">Want to add your website to the record?</p>
      <a href="/" class="btn-primary">Look Up Your Website</a>
    </div>
  </div>
</Base>
