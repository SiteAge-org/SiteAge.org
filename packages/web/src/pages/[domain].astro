---
import Base from "../layouts/Base.astro";
import CertificateCard from "../components/CertificateCard.astro";
import TombstoneCard from "../components/TombstoneCard.astro";
import EstimatedDateBanner from "../components/EstimatedDateBanner.astro";
import RankingBar from "../components/RankingBar.astro";
import BadgePreview from "../components/BadgePreview.astro";
import Timeline from "../components/Timeline.astro";
import DataSources from "../components/DataSources.astro";
import LookupLoading from "../components/LookupLoading.astro";
import ShareButtons from "../components/ShareButtons.astro";
import JsonLd from "../components/JsonLd.astro";
import { API_BASE_URL, BADGE_BASE_URL, isValidDomain, formatAge } from "@siteage/shared";
import type { DomainDetail } from "@siteage/shared";

const apiBase = import.meta.env.PUBLIC_API_URL || API_BASE_URL;
const { domain } = Astro.params;

if (!domain || !isValidDomain(domain)) {
  return Astro.redirect("/");
}

let data: DomainDetail | null = null;
let needsLookup = false;
let error: string | null = null;

try {
  const resp = await fetch(`${apiBase}/${domain}`);

  if (resp.ok) {
    data = await resp.json() as DomainDetail;
  } else if (resp.status === 404) {
    needsLookup = true;
  } else {
    const err = await resp.json().catch(() => null);
    error = (err as any)?.message || "Failed to load domain data";
  }
} catch (e) {
  error = "Unable to connect to the API";
}

// Build dynamic OG meta data
const birth = data?.verified_birth_at || data?.best_birth_at || data?.birth_at;
const yearStr = birth ? new Date(birth).getUTCFullYear().toString() : null;
const ageStr = birth ? formatAge(birth) : null;
const badgeBase = import.meta.env.PUBLIC_BADGE_URL || BADGE_BASE_URL;

const ogTitle = birth
  ? `${domain} — Online Since ${yearStr}`
  : `${domain} — Age Certificate`;
const ogDesc = birth
  ? `${domain} has been online for ${ageStr}. Discover your website's age at SiteAge.org.`
  : `Look up the age of ${domain} at SiteAge.org.`;
const ogImage = `${badgeBase}/og/${domain}`;
---

<Base title={domain} ogTitle={ogTitle} ogDescription={ogDesc} ogImage={ogImage}>
  {data && (
    <Fragment>
      <JsonLd data={{
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        itemListElement: [
          { "@type": "ListItem", position: 1, name: "Home", item: "https://siteage.org" },
          { "@type": "ListItem", position: 2, name: domain },
        ],
      }} />
      <JsonLd data={{
        "@context": "https://schema.org",
        "@type": "WebPage",
        name: ogTitle,
        description: ogDesc,
        url: `https://siteage.org/${domain}`,
        mainEntity: {
          "@type": "WebSite",
          name: domain,
          url: `https://${domain}`,
          ...(birth ? { dateCreated: birth } : {}),
        },
      }} />
    </Fragment>
  )}

  {needsLookup && (
    <LookupLoading domain={domain} apiBase={apiBase} />
  )}

  {!needsLookup && (
  <div class="max-w-4xl mx-auto px-6 py-10 sm:py-16">
    {error && (
      <div class="text-center py-16">
        <p class="text-ink-muted mb-6 font-light">{error}</p>
        <a href="/" class="text-sm text-azure hover:text-azure-light transition-colors tracking-wide">
          &larr; Return to search
        </a>
      </div>
    )}

    {data && (
      <div class="animate-fade-up">
        {data.status === "dead" ? (
          <TombstoneCard data={data} />
        ) : (
          <CertificateCard data={data} apiBase={apiBase} />
        )}
      </div>
    )}

    {data && data.verification_status !== "verified" && birth && data.status !== "dead" && (
      <div class="animate-fade-up delay-100 mt-4">
        <EstimatedDateBanner domain={data.domain} />
      </div>
    )}

    {data && (
      <div class="animate-fade-up delay-200 mt-4">
        <ShareButtons domain={data.domain} birthAt={data.verified_birth_at || data.best_birth_at || data.birth_at} deathAt={data.death_at} isDead={data.status === "dead"} isVerified={data.verification_status === "verified"} createdAt={data.created_at} />
      </div>
    )}

    {data && (
      <div class="mt-10 space-y-6">
        {data.rank_percentile !== null && (
          <div class="animate-fade-up delay-200">
            <RankingBar percentile={data.rank_percentile} />
          </div>
        )}

        <!-- Badge value proposition -->
        <div class="animate-fade-up delay-300">
          <h2 class="card-title">Display Your Age Badge</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div class="card-base p-5">
              <div class="flex items-start gap-3">
                <div class="w-8 h-8 flex-shrink-0 flex items-center justify-center bg-seal/[0.08] text-seal-dark">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/>
                  </svg>
                </div>
                <div>
                  <h3 class="font-display text-sm text-ink mb-0.5">Build Trust</h3>
                  <p class="text-xs text-ink-muted font-light leading-relaxed">Visitors trust websites with a proven track record. Years of operation increase purchase intent.</p>
                </div>
              </div>
            </div>

            <div class="card-base p-5">
              <div class="flex items-start gap-3">
                <div class="w-8 h-8 flex-shrink-0 flex items-center justify-center bg-seal/[0.08] text-seal-dark">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z"/>
                  </svg>
                </div>
                <div>
                  <h3 class="font-display text-sm text-ink mb-0.5">Third-Party Certified</h3>
                  <p class="text-xs text-ink-muted font-light leading-relaxed">An independent certification — like an SSL lock or BBB seal — adds professional credibility.</p>
                </div>
              </div>
            </div>

            <div class="card-base p-5">
              <div class="flex items-start gap-3">
                <div class="w-8 h-8 flex-shrink-0 flex items-center justify-center bg-seal/[0.08] text-seal-dark">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5M9 11.25v1.5M12 9v3.75m3-6v6"/>
                  </svg>
                </div>
                <div>
                  <h3 class="font-display text-sm text-ink mb-0.5">SEO Authority Signal</h3>
                  <p class="text-xs text-ink-muted font-light leading-relaxed">Structured data and a trusted external backlink provide authority signals to search engines.</p>
                </div>
              </div>
            </div>

            <div class="card-base p-5">
              <div class="flex items-start gap-3">
                <div class="w-8 h-8 flex-shrink-0 flex items-center justify-center bg-seal/[0.08] text-seal-dark">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456z"/>
                  </svg>
                </div>
                <div>
                  <h3 class="font-display text-sm text-ink mb-0.5">Stand Out from the Crowd</h3>
                  <p class="text-xs text-ink-muted font-light leading-relaxed">Displaying your history shows long-term dedication and separates you from fly-by-night sites.</p>
                </div>
              </div>
            </div>
          </div>
          <div class="text-center mt-4">
            <a href="/badges" class="text-sm text-azure hover:text-azure-light transition-colors tracking-wide font-medium">
              See all badge styles &rarr;
            </a>
          </div>
        </div>

        <div class="animate-fade-up delay-400">
          <BadgePreview domain={data.domain} isVerified={data.verification_status === "verified"} />
        </div>

        <!-- Claim / Manage section -->
        <div class="animate-fade-up delay-500">
          {data.verification_status === "verified" ? (
            <div class="text-center pt-2">
              <p class="text-ink-muted mb-4 font-light">This website has a verified owner.</p>
              <p class="text-sm font-light">
                <a
                  href={`/resend/${data.domain}`}
                  class="text-azure hover:text-azure-light transition-colors tracking-wide font-medium"
                >
                  Resend Magic Link
                </a>
                <span class="text-divider mx-2">|</span>
                <a
                  href={`/verify/${data.domain}`}
                  class="text-azure hover:text-azure-light transition-colors tracking-wide font-medium"
                >
                  Re-verify ownership
                </a>
              </p>
            </div>
          ) : (
            <div class="card-base p-6 border-l-3 border-l-seal/50">
              <h3 class="font-display text-lg text-ink mb-3">Unlock the Gold Seal</h3>
              <ul class="text-sm text-ink-muted font-light space-y-2 mb-5">
                <li class="flex items-start gap-2">
                  <span class="text-seal-dark mt-0.5">&#x2713;</span>
                  <span>Gold "Established" badge with verified status</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-seal-dark mt-0.5">&#x2713;</span>
                  <span>5 exclusive premium styles</span>
                </li>
                <li class="flex items-start gap-2">
                  <span class="text-seal-dark mt-0.5">&#x2713;</span>
                  <span>Downloadable HD certificate</span>
                </li>
              </ul>
              <a
                href={`/verify/${data.domain}`}
                class="inline-flex items-center gap-2 btn-seal"
              >
                Claim & Verify
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25"/>
                </svg>
              </a>
            </div>
          )}
        </div>

        {data.sources && data.sources.length > 0 && (
          <div class="animate-fade-up delay-500">
            <DataSources sources={data.sources} bestBirthAt={data.verified_birth_at || data.best_birth_at || data.birth_at} />
          </div>
        )}

        <div class="animate-fade-up delay-600">
          <Timeline domain={data.domain} firstSnapshotUrl={data.first_snapshot_url} birthAt={data.verified_birth_at || data.best_birth_at || data.birth_at} sources={data.sources} />
        </div>

        <!-- Growth CTA -->
        <div class="animate-fade-up delay-600 text-center pt-8">
          <div class="ornament-line max-w-24 mx-auto mb-6"></div>
          <p class="text-ink-muted font-light mb-4">Curious about your own website?</p>
          <a href="/" class="btn-primary">Look Up Your Website</a>
        </div>
      </div>
    )}
  </div>
  )}
</Base>
