---
import type { SourceInfo } from "@siteage/shared";
import { SOURCE_LABELS } from "@siteage/shared";

interface Props {
  sources: SourceInfo[];
  bestBirthAt: string | null;
}

const { sources, bestBirthAt } = Astro.props;

const sourceIcons: Record<string, string> = {
  cdx: "M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418",
  crt: "M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z",
  rdap: "M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z",
  whois: "M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z",
  commoncrawl: "M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125v-3.75m16.5 3.75v3.75c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125v-3.75",
};

const confidenceColors: Record<string, string> = {
  high: "text-ink bg-ink/5 border-ink/10",
  medium: "text-seal-dark bg-seal/10 border-seal/20",
  low: "text-ink-muted bg-divider/30 border-divider",
};

function formatDate(iso: string): string {
  return new Date(iso).toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
    timeZone: "UTC",
  });
}

function getSummaryText(source: SourceInfo): string {
  const s = source.summary;
  switch (source.source) {
    case "cdx":
      return s.snapshot_count ? `${s.snapshot_count} snapshots` : "";
    case "crt":
      return s.cert_count ? `${s.cert_count} certificates` : "";
    case "rdap":
    case "whois":
      return s.registrar ? `Registrar: ${s.registrar}` : "";
    case "commoncrawl":
      return s.indexes_queried ? `${s.indexes_queried} indexes queried` : "";
    default:
      return "";
  }
}

const successCount = sources.filter((s) => !s.error && s.earliest_date).length;
---

{sources.length > 0 && (
  <div class="card-base p-6 sm:p-8">
    <h2 class="card-title">Data Sources</h2>

    <div class="space-y-4 mt-4">
      {sources.map((source) => {
        const icon = sourceIcons[source.source] || sourceIcons.cdx;
        const summaryText = getSummaryText(source);
        const hasError = !!source.error;
        const hasDate = !!source.earliest_date;

        return (
          <div class={`flex items-start gap-3 p-3 rounded border ${hasError ? "border-divider/50 opacity-60" : "border-divider"}`}>
            <svg class={`w-5 h-5 mt-0.5 shrink-0 ${hasError ? "text-ink-muted/40" : "text-azure"}`} fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d={icon} />
            </svg>

            <div class="flex-1 min-w-0">
              <div class="flex items-center justify-between gap-2">
                <span class="font-display text-sm text-ink">{source.source_label}</span>
                {hasDate && (
                  <span class="text-sm font-medium text-ink whitespace-nowrap">
                    {formatDate(source.earliest_date!)}
                  </span>
                )}
                {!hasDate && !hasError && (
                  <span class="text-xs text-ink-muted font-light">No records</span>
                )}
                {hasError && (
                  <span class="text-xs text-ink-muted font-light">Unavailable</span>
                )}
              </div>

              <div class="flex items-center gap-2 mt-1 flex-wrap">
                {!hasError && (
                  <span class={`inline-flex items-center px-1.5 py-0.5 text-[10px] tracking-wider uppercase border rounded ${confidenceColors[source.confidence]}`}>
                    {source.confidence}
                  </span>
                )}
                {summaryText && (
                  <span class="text-xs text-ink-muted font-light">{summaryText}</span>
                )}
              </div>

              {source.detail_url && !hasError && (
                <a
                  href={source.detail_url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1 text-xs text-azure hover:text-azure-light mt-1.5 transition-colors"
                >
                  View source
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25"/>
                  </svg>
                </a>
              )}
            </div>
          </div>
        );
      })}
    </div>

    {/* Best estimate summary */}
    {bestBirthAt && successCount > 0 && (
      <div class="mt-6 pt-4 border-t border-divider">
        <div class="flex items-center justify-between">
          <span class="text-xs tracking-[0.15em] uppercase text-ink-muted font-medium">Best Estimate</span>
          <span class="font-display text-lg text-ink">{formatDate(bestBirthAt)}</span>
        </div>
        <p class="text-xs text-ink-muted font-light mt-1">
          Earliest date across {successCount} data source{successCount !== 1 ? "s" : ""}
        </p>
      </div>
    )}
  </div>
)}
