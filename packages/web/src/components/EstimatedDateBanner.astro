---
interface Props {
  domain: string;
}

const { domain } = Astro.props;
---

<div class="flex gap-4 bg-[var(--color-seal-glow)] border border-seal/30 p-4 sm:p-5">
  <!-- Left gold accent line -->
  <div class="w-[3px] flex-shrink-0 bg-gradient-to-b from-seal to-seal/40 rounded-full"></div>

  <div class="flex-1 min-w-0">
    <!-- Warning headline -->
    <div class="flex items-center gap-2 mb-2">
      <svg class="w-4 h-4 flex-shrink-0 text-seal-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/>
      </svg>
      <span class="text-xs tracking-[0.1em] uppercase text-seal-dark font-medium">Estimated date — may not be accurate</span>
    </div>

    <!-- Explanation -->
    <p class="text-xs text-ink-muted font-light leading-relaxed">
      This date is automatically estimated from public sources (Wayback Machine, crt.sh, RDAP, Common Crawl) and may differ from the actual launch date.
      <a
        href={`/verify/${domain}`}
        class="text-azure hover:text-azure-light transition-colors font-medium whitespace-nowrap"
      >Claim this domain to correct it &rarr;</a>
    </p>
  </div>
</div>
