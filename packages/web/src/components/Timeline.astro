---
import type { SourceInfo } from "@siteage/shared";

interface Props {
  domain: string;
  firstSnapshotUrl: string | null;
  birthAt: string | null;
  sources?: SourceInfo[];
}

const { domain, firstSnapshotUrl, birthAt, sources } = Astro.props;

// Build timeline nodes from sources
interface TimelineNode {
  date: string;
  label: string;
  sublabel: string;
  url: string | null;
  colorClass: string;
}

const sourceColors: Record<string, string> = {
  cdx: "border-azure",
  crt: "border-seal",
  rdap: "border-ink",
  whois: "border-ink",
  commoncrawl: "border-azure/60",
};

const nodes: TimelineNode[] = [];

if (sources && sources.length > 0) {
  // Add source nodes (only those with dates)
  for (const source of sources) {
    if (source.earliest_date && !source.error) {
      nodes.push({
        date: source.earliest_date,
        label: source.source_label,
        sublabel: new Date(source.earliest_date).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" }),
        url: source.detail_url,
        colorClass: sourceColors[source.source] || "border-azure",
      });
    }
  }
  // Sort chronologically
  nodes.sort((a, b) => a.date.localeCompare(b.date));
} else if (birthAt) {
  // Fallback: single CDX node (legacy mode)
  nodes.push({
    date: birthAt,
    label: "Earliest known snapshot",
    sublabel: new Date(birthAt).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" }),
    url: firstSnapshotUrl,
    colorClass: "border-azure",
  });
}
---

{nodes.length > 0 && (
  <div class="card-base p-6 sm:p-8">
    <h2 class="card-title">Timeline</h2>
    <div class="relative pl-6 space-y-8 before:absolute before:left-[5px] before:top-2 before:bottom-2 before:w-px before:bg-gradient-to-b before:from-azure before:via-divider before:to-seal">
      {nodes.map((node) => (
        <div class="relative">
          <div class={`absolute -left-6 top-1 w-[11px] h-[11px] rounded-full ${node.colorClass} border-2 bg-parchment shadow-[0_0_0_3px_rgba(43,94,167,0.1)]`}></div>
          <div>
            <p class="font-display text-base text-ink">{node.sublabel}</p>
            <p class="text-xs text-ink-muted mt-1 font-light">{node.label}</p>
            {node.url && (
              <a href={node.url} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1 text-xs text-azure hover:text-azure-light mt-2 transition-colors">
                View source
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25"/>
                </svg>
              </a>
            )}
          </div>
        </div>
      ))}
      <div class="relative">
        <div class="absolute -left-6 top-1 w-[11px] h-[11px] rounded-full border-2 border-seal bg-parchment" style="animation: seal-pulse 2s ease-in-out infinite;"></div>
        <div>
          <p class="font-display text-base text-ink">Today</p>
          <p class="text-xs text-ink-muted mt-1 font-light">Still going strong</p>
        </div>
      </div>
    </div>
  </div>
)}
